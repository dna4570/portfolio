# Shopify のストア/商品ページ URL
# 例: https://your-store.myshopify.com/products/your-product
VITE_SHOPIFY_URL=

# Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...

# 任意: Payment Element / Stripe.js 用（Checkout リダイレクトのみなら未設定可）
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Products → 商品の Price ID（price_...）
VITE_STRIPE_PRICE_ID=price_...
